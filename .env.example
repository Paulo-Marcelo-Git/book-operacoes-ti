# ============================================================
#  EXEMPLO de configuração. Copie para .env e preencha.
#  O .env real NÃO é versionado (ver .gitignore).
#  NÃO coloque segredos aqui neste arquivo de exemplo.
# ============================================================

# ---- Inbox local ----
INBOX_DIR=inbox          # pasta onde a planilha é depositada diariamente

# ---- Email (Gmail) ----
EMAIL_USER=seu_bot@gmail.com
EMAIL_PASS=                 # App Password de 16 dígitos do Gmail (NUNCA commitar)
EMAIL_DESTINATARIO=destino@exemplo.com   # aceita vários separados por vírgula
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORTA=587            # STARTTLS. Alternativa: 465 (SSL)
EMAIL_ASSUNTO_PREFIXO=Book Operações de TI

# ---- Telegram (alertas) ----
TELEGRAM_TOKEN=            # token do @BotFather
TELEGRAM_CHAT_ID=         # id do chat/grupo de destino

# ---- App ----
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0
TIMEZONE=America/Sao_Paulo
OUTPUT_DIR=output
LOG_DIR=logs
